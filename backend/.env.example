# ──────────────────────────────────────────────
# GigArmor Backend — Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Database ───────────────────────────────────
# Default: SQLite (zero-config, great for demos)
DATABASE_URL=sqlite:///./gigarmor.db

# PostgreSQL alternative (uncomment to switch):
# DATABASE_URL=postgresql://gigarmor:secret@localhost:5432/gigarmor_db

# ── Redis (optional) ───────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── App Settings ───────────────────────────────
APP_ENV=development
SECRET_KEY=changeme-super-secret-key-for-production
DEBUG=true

# ── UPI Webhook (Mock for demo) ────────────────
UPI_WEBHOOK_URL=https://mock-upi.example.com/payout
UPI_API_KEY=mock-api-key-replace-in-production
