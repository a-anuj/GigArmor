# ─────────────────────────────────────────────────
# HustleHalt Backend — Environment Variable Reference
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────

# Database — Supabase PostgreSQL in production
DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres

# SQLite alternative for local dev (zero-config, just for running locally)
# DATABASE_URL=sqlite:///./hustlehalt.db

# Redis — optional locally, recommended in production for burst detection
REDIS_URL=redis://localhost:6379/0

# App
APP_ENV=development
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
DEBUG=true

# UPI Payout Gateway — mock for demo, replace with Razorpay in production
UPI_WEBHOOK_URL=https://mock-upi.example.com/payout
UPI_API_KEY=mock-api-key-replace-in-production

# OpenWeatherMap — sign up free at openweathermap.org/api (1000 calls/day)
OPENWEATHERMAP_API_KEY=your-owm-key-here

# AQICN — sign up free at aqicn.org/api
AQICN_API_TOKEN=your-aqicn-token-here

# Set to false to skip live API calls and use hardcoded zone data (good for CI / offline demo)
USE_REAL_WEATHER_API=true
